import os
import json
import re
import time
from openai import AzureOpenAI

from config import (
    AZURE_OPENAI_KEY,
    AZURE_OPENAI_ENDPOINT,
    AZURE_OPENAI_API_VERSION
)

client = AzureOpenAI(
    api_key=AZURE_OPENAI_KEY,
    api_version=AZURE_OPENAI_API_VERSION,
    azure_endpoint=AZURE_OPENAI_ENDPOINT
)

MODEL_MINI = "gpt-4.1-mini"
MODEL_FULL = "gpt-4.1"


# ─────────────────────────────────────────────
# Utilities
# ─────────────────────────────────────────────

def estimate_tokens(text: str) -> int:
    return len(text) // 4


def choose_model(text: str) -> str:
    return MODEL_MINI if estimate_tokens(text) < 8000 else MODEL_FULL


def trim_text(text: str, max_tokens=12000):
    if estimate_tokens(text) <= max_tokens:
        return text

    chars = max_tokens * 4
    return text[:chars//2] + "\n...\n" + text[-chars//2:]


def clean_json(content: str):
    content = re.sub(r"```json|```", "", content).strip()

    try:
        return json.loads(content)
    except:
        try:
            start = content.find("{")
            end = content.rfind("}") + 1
            return json.loads(content[start:end])
        except:
            return None


# ─────────────────────────────────────────────
# NEW: MULTI-PAGE EXPLANATION
# ─────────────────────────────────────────────

def generate_explanation(pages, max_retries=3, custom_prompt=None, language="en") -> tuple[dict, float, float]:
    combined_text = "\n\n".join([p["text"] for p in pages])
    combined_text = trim_text(combined_text)

    model = MODEL_FULL

    # ── Language instruction ─────────────────────────────
    if language == "hi-en":
        lang_instruction = """
LANGUAGE MODE: Bilingual Hindi-English (Hinglish style used by Indian students)

Generate ALL outputs in BOTH Hindi and English using the following rules:

FOR HINDI FIELDS (explanation_hi, definition_hi, example_hi, context_hi):
- Write primarily in Hindi (Devanagari script)
- Every technical term, concept name, or domain-specific word MUST appear in English inside brackets immediately after its Hindi equivalent
- Example style: "State Reduction एक ऐसी process (प्रक्रिया) है जिसमें State Machine के states (अवस्थाओं) की संख्या को उसके external behavior (बाहरी व्यवहार) को बदले बिना कम किया जाता है।"
- Keep the flow natural, like how an Indian engineering student would explain to a friend

FOR ENGLISH FIELDS (explanation_en, definition_en, example_en, context_en):
- Write primarily in English
- After complex or technical sentences/phrases, add the Hindi equivalent in brackets
- Example style: "The flip-flop stores a single bit of state (यह एक bit की जानकारी store करता है). It transitions on the clock edge (clock के pulse पर अवस्था बदलती है)."
- Only annotate sentences that a student might struggle with; don't annotate every single sentence

FOR TERM FIELDS (term_hi, term_en):
- term_en: English term only
- term_hi: Hindi equivalent with English term in brackets, e.g., "राज्य कमी (State Reduction)"

USE KEYS:
    explanation_hi, explanation_en
    term_hi, term_en
    definition_hi, definition_en
    example_hi, example_en
    context_hi, context_en
"""
    else:
        lang_instruction = f"""
Generate ALL outputs strictly in language code: {language}.
Do NOT mix languages.
"""

    # ── Custom instruction ───────────────────────────────
    custom_instruction = ""
    if custom_prompt and custom_prompt.strip():
        custom_instruction = f"""

USER'S CUSTOM INSTRUCTION:
{custom_prompt.strip()}

IMPORTANT RULES FOR CUSTOM INSTRUCTION:
- Follow this instruction strictly without hallucinating.
- If the instruction asks to list formulas, equations, or derivations:
    → DO NOT create a separate top-level key for them.
    → Instead, embed them WITHIN the JSON structure using one of these two approaches:
        OPTION A (preferred for formula summaries): Append them clearly in the explanation of the LAST page.
          Add a section like "\\n\\nFORMULAS SUMMARY:\\n- Formula 1: ...\\n- Formula 2: ..."
        OPTION B (preferred when formulas are conceptual): Add each formula as the LAST entry/entries in the "concepts" array,
          using term = formula name, definition = what it means, example = how to apply it.
    → Choose OPTION A if the user just wants a list/reference.
    → Choose OPTION B if the formula represents a standalone learnable concept.
- Apply the same logic for any other structured data the user asks for (e.g., theorems, rules, laws):
    embed inside "main" or "concepts", never as a new top-level key.
"""

    # ── Prompt ───────────────────────────────────────────
    prompt = f"""
You are an expert AI tutor.

You are given OCR text from multiple pages.

INPUT:
{pages}

{lang_instruction}

{custom_instruction}

TASK:

1. Generate a SEPARATE explanation for EACH page.
2. Maintain page order.
3. Keep explanations clear and student-friendly.
4. If math exists, explain step-by-step.
5. Extract IMPORTANT CONCEPTS across ALL pages.
6. Also estimate:
   - llm_stress_signal: a number between 0 and 1 for how stressed/confused the student request sounds
   - llm_confusion_keywords: integer count of confusion indicators in the request
7. CRITICAL: Output ONLY the keys defined in the JSON schema below.

RETURN STRICT JSON:

IF language is NOT hi-en:
{{
  "meta": {{
    "llm_stress_signal": 0.0,
    "llm_confusion_keywords": 0
  }},
  "main": [
    {{
      "page": 1,
      "explanation": ""
    }}
  ],
  "concepts": [
    {{
      "term": "",
      "definition": "",
      "example": "",
      "context": "",
      "difficulty": "easy | medium | hard",
      "related_topics": [],
      "prerequisites": [],
      "youtube_link": "",
      "wikipedia_link": ""
    }}
  ]
}}

IF language is hi-en:
{{
  "meta": {{
    "llm_stress_signal": 0.0,
    "llm_confusion_keywords": 0
  }},
  "main": [
    {{
      "page": 1,
      "explanation_hi": "",
      "explanation_en": ""
    }}
  ],
  "concepts": [
    {{
      "term_hi": "",
      "term_en": "",
      "definition_hi": "",
      "definition_en": "",
      "example_hi": "",
      "example_en": "",
      "context_hi": "",
      "context_en": "",
      "difficulty": "easy | medium | hard",
      "related_topics": [],
      "prerequisites": [],
      "youtube_link": "",
      "wikipedia_link": ""
    }}
  ]
}}

RULES:
- STRICT JSON only — no markdown, no code fences
- No hallucinated links
- Avoid trivial concepts
- NEVER add keys outside of "meta", "main" and "concepts" — this will break the parser
- Formulas or any extra content requested via custom instruction must be embedded inside "main[last page].explanation" or appended as entries in "concepts"
"""

    # ── Retry loop ────────────────────────────────────────
    for attempt in range(max_retries):
        try:
            response = client.chat.completions.create(
                model=model,
                messages=[
                    {"role": "system", "content": "You are a structured AI teacher. You always return valid JSON with only 'meta', 'main' and 'concepts' as top-level keys. You never add extra keys."},
                    {"role": "user", "content": prompt}
                ],
                temperature=0.2,
            )

            content = response.choices[0].message.content
            parsed = clean_json(content)

            # ── Safety check: strip rogue top-level keys ──
            if parsed and isinstance(parsed, dict):
                allowed_keys = {"meta", "main", "concepts"}
                rogue_keys = set(parsed.keys()) - allowed_keys
                if rogue_keys:
                    # Salvage: move rogue content into last page's explanation
                    last_page = parsed.get("main", [{}])[-1]
                    for key in rogue_keys:
                        rogue_data = parsed.pop(key)
                        suffix = f"\n\n{key.upper()}:\n"
                        if isinstance(rogue_data, list):
                            for item in rogue_data:
                                if isinstance(item, dict):
                                    for k, v in item.items():
                                        suffix += f"- {k}: {v}\n"
                                else:
                                    suffix += f"- {item}\n"
                        else:
                            suffix += str(rogue_data)
                        # Append to whichever explanation key exists
                        for exp_key in ("explanation", "explanation_en", "explanation_hi"):
                            if exp_key in last_page:
                                last_page[exp_key] += suffix

            if parsed:
                meta = parsed.get("meta", {}) if isinstance(parsed.get("meta"), dict) else {}
                llm_stress_signal = float(meta.get("llm_stress_signal", 0.0) or 0.0)
                llm_confusion_keywords = float(meta.get("llm_confusion_keywords", 0) or 0)
                return parsed, llm_stress_signal, llm_confusion_keywords

        except Exception as e:
            print(f"Attempt {attempt+1} failed:", e)

        time.sleep(1)

    # ── Fallback ──────────────────────────────────────────
    return {
        "main": [
            {"page": p["page"], "explanation": p["text"][:1000]}
            for p in pages
        ],
        "concepts": []
    }, 0.0, 0.0
